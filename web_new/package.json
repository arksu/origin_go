{
  "name": "origin-web-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run proto && vite",
    "build": "npm run proto && vue-tsc --build && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build --force",
    "validate-objects": "node scripts/validate-object-schema.mjs",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "proto": "pbjs -t static-module -w es6 -o src/network/proto/packets.js ../api/proto/packets.proto && pbts -o src/network/proto/packets.d.ts src/network/proto/packets.js"
  },
  "dependencies": {
    "@esotericsoftware/spine-pixi-v8": "^4.2.106",
    "axios": "^1.13.6",
    "howler": "^2.2.4",
    "pinia": "^3.0.4",
    "pixi.js": "^8.16.0",
    "protobufjs": "^7.5.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.16.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/howler": "^2.2.12",
    "@types/node": "^25.3.5",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "protobufjs-cli": "^2.0.0",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5"
  }
}